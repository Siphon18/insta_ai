# Required
GROQ_API_KEY=your-groq-api-key
RAPIDAPI_KEY=your-rapidapi-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key
DATABASE_URL=postgresql://user:password@localhost:5432/insta_ai
JWT_SECRET=your-very-strong-random-secret

# Optional
PORT=3000
NODE_ENV=development
ADMIN_EMAILS=admin@example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Groq model controls
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_PRIMARY=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACK=llama-3.1-8b-instant

# ElevenLabs voice controls
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_DEFAULT_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_MALE_1=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_VOICE_MALE_2=N2lVS1w4EtoT3dr4eOWO
ELEVENLABS_VOICE_MALE_3=ErXwobaYiN019PkySvjV
ELEVENLABS_VOICE_FEMALE_1=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_FEMALE_2=XrExE9yKIg1WjnnlVkGX
ELEVENLABS_VOICE_FEMALE_3=MF3mGyEYCl7XYWbV9V6O

# RapidAPI limits
RAPIDAPI_RATE_WINDOW_MS=3600000
RAPIDAPI_RATE_LIMIT_GENERATE_PER_WINDOW=2
RAPIDAPI_RATE_LIMIT_POSTS_PER_WINDOW=6
RAPIDAPI_DAILY_BUDGET=5
RAPIDAPI_MONTHLY_BUDGET=145

# Login brute-force protection (per IP)
AUTH_LOGIN_RATE_WINDOW_MS=900000
AUTH_LOGIN_RATE_LIMIT_PER_WINDOW=8


